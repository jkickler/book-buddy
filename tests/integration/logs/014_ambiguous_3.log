er_rating": 5.0, "openlib_ratings_count": 10, "published_year": 2012, "openlib_average_rating": 3.7, "isbn13": "9780812993295", "google_id": "WH0KnwEACAAJ", "published_date": "2012", "subjects": ["pilgrimage", "walking", "men", "fiction", "letters", "humorous_fiction", "self_acceptance", "roman", "englisch", "married_people_fiction", "fiction_humorous_general", "england_fiction", "fiction_humorous", "large_type_books", "new_york_times_reviewed", "middle_aged_men", "redemption", "litt_rature_anglaise", "pension_rer", "brev", "cancer", "d_den", "personlig_utveckling", "chang_pian_xiao_shuo"], "authors": ["Rachel Joyce"], "page_count": 0, "url": "http://books.google.de/books?id=WH0KnwEACAAJ&dq=isbn:9780812993295&hl=&as_pt=BOOKS&source=gbs_api", "goodreads_community_rating": 3.94, "title": "The Unlikely Pilgrimage of Harold Fry (Harold Fry, #1)", "openlib_key": "/works/OL16471523W", "isbn10": "0812993292"}}]}}, {"title": "Wuthering Heights - Emily Bronte", "authors": ["Emily Bronte"], "description": "Published in 1847, Emily Bronte's only novel Wuthering Heights is an evergreen classic. A passionate tale of love between Catherine Earnshaw and Heathcliff, the novel challenged Victorian ideals of morality, class, religion and gender inequality. Heathcliff, an orphan, brought to Wuthering Heights by Mr. Earnshaw, represents the quintessential Byronic herobrooding and enigmatic, whose social status is foregrounded by his lack of a first name. Spurned by Catherine and humiliated by her brother, Hindley, Heathcliff leaves the Heights, only to return later as a revenge-seeking, wealthy and polished man. Catherine chooses to marry Edgar Linton, an antithesis to Heathcliff. What follows is a series of disastrous events in which the characters are consumed by their tragic fate. Evocative and gothic, the novel was initially termed abhorrent and later appreciated for its originality and poetic grandeur.", "subjects": ["Literary Criticism"], "isbn13": "9783985511372", "isbn10": "398